{
  "all": true,
  "src": ["bin", "test"],
  "exclude": [
    "**/*.test.js",
    "node_modules/**",
    "nemoclaw/node_modules/**",
    "nemoclaw/dist/**",
    "nemoclaw-blueprint/**",
    "docs/**",
    ".devcontainer/**",
    ".github/**",
    "scripts/**",
    "coverage/**",
    ".jscpd/**"
  ],
  "reporter": ["text", "lcov", "html"],
  "reports-dir": "coverage",
  "check-coverage": true,
  "lines": 30,
  "functions": 40,
  "branches": 65,
  "statements": 30,
  "per-file": false
}
