# NemoClaw Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control - it contains secrets!

# ========================================
# Required: NVIDIA API Configuration
# ========================================
# Get your API key from: https://build.nvidia.com
# Used for NVIDIA cloud inference (nemotron models)
NVIDIA_API_KEY=your_nvidia_api_key_here

# ========================================
# Optional: Messaging Bridge Tokens
# ========================================
# Telegram Bot Token (from @BotFather)
# Only required if using Telegram bridge
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Slack Bot Token (from Slack App Settings)
# Only required if using Slack integration
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Discord Bot Token (from Discord Developer Portal)
# Only required if using Discord integration
# DISCORD_BOT_TOKEN=your_discord_bot_token

# ========================================
# Optional: Local Development
# ========================================
# Chat UI URL for local development
# Default: http://127.0.0.1:18789
# CHAT_UI_URL=http://127.0.0.1:18789

# GitHub Personal Access Token
# Required for private repository operations
# GITHUB_TOKEN=ghp_your_github_token

# ========================================
# Optional: Custom Inference Endpoints
# ========================================
# OpenAI API Key (if using OpenAI-compatible endpoints)
# OPENAI_API_KEY=sk-your-openai-key

# Custom OpenAI Base URL (for local or alternative endpoints)
# OPENAI_BASE_URL=http://localhost:8000/v1

# ========================================
# Optional: Error Tracking (Sentry)
# ========================================
# Enable Sentry error tracking for production monitoring and debugging.
# Get your DSN from: https://sentry.io/settings/[org]/projects/[project]/keys/
# Sentry provides contextualized error tracking with source maps, breadcrumbs,
# and distributed tracing integration. Opt-in only - disabled by default.

# Sentry Data Source Name (DSN) - enables error tracking when set
# SENTRY_DSN=https://abc123@o123456.ingest.sentry.io/789

# Environment name (development, staging, production)
# SENTRY_ENVIRONMENT=production

# Release version (auto-detected from git if not set)
# SENTRY_RELEASE=v1.2.3

# Error sampling rate: 0.0-1.0 (default: 1.0 = capture all errors)
# SENTRY_SAMPLE_RATE=1.0

# Performance monitoring sampling rate: 0.0-1.0 (default: 0.1 = 10% of transactions)
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Sentry-GitHub Integration (Error to Insight Pipeline)
# Enables automatic GitHub issue creation from production errors
# Get from: https://sentry.io/settings/[org]/projects/[project]/
# SENTRY_ORG=your-organization-slug
# SENTRY_PROJECT=nemoclaw

# ========================================
# Optional: Product Analytics (PostHog)
# ========================================
# Enable product analytics to track feature usage and measure impact.
# PostHog is privacy-focused and can be self-hosted.
# Get your project API key from: https://app.posthog.com/project/settings

# PostHog Project API Key (enables analytics when set)
# POSTHOG_API_KEY=phc_your_project_api_key_here

# PostHog Host (default: https://app.posthog.com for cloud, or your self-hosted URL)
# POSTHOG_HOST=https://app.posthog.com

# Disable telemetry (opt-out for privacy)
# NEMOCLAW_TELEMETRY=0

# ========================================
# Feature Flags (Experimental Features)
# ========================================
# Feature flags enable safe rollout of experimental features.
# Set to 1, true, yes, or on to enable. All default to disabled.
# See docs/feature-flags.md for full documentation.

# Enable all experimental features (master switch)
# NEMOCLAW_EXPERIMENTAL=0

# Enable local inference endpoints (NIM, vLLM, Ollama)
# NEMOCLAW_LOCAL_INFERENCE=0

# Auto-select detected inference providers during onboarding
# NEMOCLAW_AUTO_SELECT=0

# Enable verbose debug logging
# NEMOCLAW_VERBOSE=0

# Enable anonymous usage telemetry (not yet implemented)
# NEMOCLAW_TELEMETRY=0

# ========================================
# Security Notes
# ========================================
# 1. Never commit this file with real values
# 2. Keep .env in .gitignore (already configured)
# 3. Use environment-specific files (.env.development, .env.production) if needed
# 4. Rotate keys regularly
# 5. Use minimal permissions for all tokens
