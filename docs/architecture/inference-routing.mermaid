graph LR
    subgraph "Client Application"
        App[OpenClaw Plugin<br/>in IDE]
        Cache[Response Cache]
    end

    subgraph "NemoClaw Sandbox"
        Router[Inference Router<br/>OpenShell Gateway]
        Auth[Authentication<br/>Credential Manager]
        Metrics[Metrics Collector<br/>Telemetry]
    end

    subgraph "Inference Providers"
        NVIDIA[NVIDIA Cloud API<br/>build.nvidia.com]
        NIM[Local NIM<br/>Containerized]
        vLLM[vLLM Server<br/>Local/Remote]
        Ollama[Ollama<br/>Local Models]
    end

    subgraph "Observability"
        Logs[Structured Logs<br/>pino]
        Traces[Distributed Tracing<br/>Trace IDs]
        Sentry[Error Tracking<br/>Sentry]
    end

    App -->|Inference Request| Router
    Router -->|Check Cache| Cache
    Cache -.->|Cache Hit| App
    Router -->|Authenticate| Auth
    Router -->|Select Provider| Router

    Router -->|Route: Cloud| NVIDIA
    Router -->|Route: Local NIM| NIM
    Router -->|Route: vLLM| vLLM
    Router -->|Route: Ollama| Ollama

    NVIDIA -->|Response| Router
    NIM -->|Response| Router
    vLLM -->|Response| Router
    Ollama -->|Response| Router

    Router -->|Update Cache| Cache
    Router -->|Record Metrics| Metrics
    Router -->|Write Logs| Logs
    Router -->|Trace Context| Traces
    Router -->|Report Errors| Sentry
    Router -->|Final Response| App

    style NVIDIA fill:#76b900
    style NIM fill:#76b900
    style vLLM fill:#76b900
    style Ollama fill:#76b900
    style Router fill:#e1f5ff
    style App fill:#fff4e1
