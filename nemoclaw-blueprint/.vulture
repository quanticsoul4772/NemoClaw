# Vulture configuration for dead code detection
# Minimum confidence: 80% (0-100 scale)
# Higher confidence = fewer false positives, but might miss some dead code
# Lower confidence = catches more dead code, but more false positives

# Ignore patterns (files/directories to skip)
*.pyc
__pycache__
.venv
venv
env
.git

# Whitelisted names (known false positives)
# Example: Functions/variables that appear unused but are actually used externally
# Add entries like: some_function_name
# Or: ClassName.method_name
