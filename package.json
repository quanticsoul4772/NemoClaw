{
  "name": "nemoclaw",
  "version": "0.1.0",
  "description": "NemoClaw — run OpenClaw inside OpenShell with NVIDIA inference",
  "license": "Apache-2.0",
  "bin": {
    "nemoclaw": "./bin/nemoclaw.js"
  },
  "scripts": {
    "test": "node --test --test-concurrency=4 test/*.test.js",
    "test:all": "node --test --test-concurrency=4 test/*.test.js test/integration/*.test.js",
    "test:integration": "node --test test/integration/*.test.js",
    "test:serial": "node --test --test-concurrency=1 test/*.test.js",
    "test:timing": "node --test --test-reporter=spec --test-concurrency=4 test/*.test.js",
    "test:coverage": "c8 node --test --test-concurrency=4 test/*.test.js",
    "changelog": "node scripts/generate-changelog.js",
    "changelog:full": "node scripts/generate-changelog.js --full",
    "prepublishOnly": "cd nemoclaw && npm install --ignore-scripts && npm run build",
    "duplicates": "jscpd .",
    "tech-debt": "leasot --reporter markdown bin/**/*.js nemoclaw/src/**/*.ts nemoclaw-blueprint/**/*.py test/**/*.js --skip-unsupported"
  },
  "dependencies": {
    "@sentry/node": "^10.45.0",
    "openclaw": "2026.3.11",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^13.0.0",
    "ws": "^8.20.0"
  },
  "files": [
    "bin/",
    "nemoclaw/dist/",
    "nemoclaw/openclaw.plugin.json",
    "nemoclaw/package.json",
    "nemoclaw-blueprint/",
    "scripts/",
    "Dockerfile",
    ".dockerignore"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NVIDIA/NemoClaw.git"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "jscpd": "^4.0.8",
    "leasot": "^14.4.0"
  }
}
